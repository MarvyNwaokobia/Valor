# ─────────────────────────────────────────────────────────────
# Valor API (Rust/Actix) — Environment Variables
# Copy this file to .env and fill in each value.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# Local dev only — Railway production gets its own DATABASE_URL injected
# automatically by the Railway Postgres plugin and does NOT use Supabase.
# Supabase: Settings → Database → Connection string (URI)
# Use the "Session" pooler URL (port 5432), not "Transaction" (6543) — sqlx's
# named prepared statements collide under PgBouncer transaction-mode pooling:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Server ───────────────────────────────────────────────────
RUST_LOG=info
BIND_ADDR=0.0.0.0:8080

# ── Celo RPC ─────────────────────────────────────────────────
# Primary: Celo Foundation node (free, no key needed)
CELO_RPC_URL=https://forno.celo.org

# ── GoodDollar Identity (optional — frontend handles this) ───
GOOD_DOLLAR_API_URL=https://gooddollar-api.gooddollar.org

# ── Engagement Rewards — EIP-712 Signing ─────────────────────
# Private key of the wallet that signs AppClaim messages.
# This wallet must be registered (or set as signer via setAppSigner) on:
# https://engagement-rewards.vercel.app
# NEVER commit this key. Generate a dedicated hot wallet.
BACKEND_PRIVATE_KEY=

# The app wallet address registered on the Engagement Rewards contract.
# Defaults to the address derived from BACKEND_PRIVATE_KEY if not set.
# Must match what was registered at engagement-rewards.vercel.app
VALOR_APP_ADDRESS=

# Override the production contract address (leave blank to use default)
# Default: 0x25db74CF4E7BA120526fd87e159CF656d94bAE43
ENGAGEMENT_REWARDS_CONTRACT=

# ── On-Chain Contracts ──────────────────────────────────────
# From Deploy.s.sol output. Leave blank to disable chain writes.
GAME_RECORD_CONTRACT=
# ValorMarketplace proxy — enables permit relay purchases.
MARKETPLACE_CONTRACT=

# ── Decay Sweep (cron) ───────────────────────────────────────
# Secret token sent in Authorization header by the cron job.
# Generate any random string: openssl rand -hex 32
DECAY_CRON_SECRET=
