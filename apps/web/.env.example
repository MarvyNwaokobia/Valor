# ─────────────────────────────────────────────────────────────
# Valor Frontend — Environment Variables
# Copy this file to .env.local and fill in each value.
# NEXT_PUBLIC_* vars are bundled into the client — never put secrets here.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API → Project API Keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Web3Auth ─────────────────────────────────────────────────
# dashboard.web3auth.io → create project → Client ID
# Required: without this the login modal will not open.
# Confirm in the dashboard that this Client ID has Celo mainnet + Alfajores
# enabled as custom chains, and that Google login is working end-to-end.
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=

# ── Backend API ──────────────────────────────────────────────
# Local dev: http://localhost:8080
# Production: your Railway app URL, e.g. https://valor-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080
# WebSocket URL is auto-derived from API_URL (http→ws / https→wss).
# Only override if your WS server lives on a different host.
# NEXT_PUBLIC_WS_URL=

# ── GoodDollar ───────────────────────────────────────────────
# "production" | "staging" — leave as production for mainnet Celo
NEXT_PUBLIC_GOODDOLLAR_ENV=production

# The wallet address you registered on engagement-rewards.vercel.app
# Leave blank until you register — canClaim() will return false otherwise
NEXT_PUBLIC_VALOR_APP_ADDRESS=

# ── Smart Contracts (fill after deployment) ──────────────────
# ValorMarketplace.sol deployed address on Celo mainnet
NEXT_PUBLIC_MARKETPLACE_CONTRACT=
