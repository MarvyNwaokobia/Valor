# ─────────────────────────────────────────────────────────────
# Valor — Master Reference
# This file documents ALL env vars across the monorepo.
# Each app has its own .env / .env.local — fill those in.
# ─────────────────────────────────────────────────────────────


# ╔══════════════════════════════════════════════════════════════╗
# ║  apps/web  (.env.local)                                      ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Supabase ─────────────────────────────────────────────────
# supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Privy ─────────────────────────────────────────────────────
# dashboard.privy.io → App Settings → App ID
NEXT_PUBLIC_PRIVY_APP_ID=clxxxxxxxxxxxxxxxx

# ── API ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080          # dev
# NEXT_PUBLIC_API_URL=https://valor-api.up.railway.app   # prod

# ── GoodDollar ────────────────────────────────────────────────
NEXT_PUBLIC_GOODDOLLAR_ENV=production              # production | staging
NEXT_PUBLIC_VALOR_APP_ADDRESS=0x...               # your registered app wallet

# ── Contracts (post-deploy) ───────────────────────────────────
NEXT_PUBLIC_MARKETPLACE_CONTRACT=0x...


# ╔══════════════════════════════════════════════════════════════╗
# ║  apps/api  (.env)                                            ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────
# Supabase → Settings → Database → Transaction pooler URI
DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:6543/postgres

# ── Server ────────────────────────────────────────────────────
RUST_LOG=info
BIND_ADDR=0.0.0.0:8080

# ── Celo ──────────────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org

# ── GoodDollar ────────────────────────────────────────────────
GOOD_DOLLAR_API_URL=https://gooddollar-api.gooddollar.org

# ── Engagement Rewards Signing ────────────────────────────────
# ⚠️  Keep secret — this wallet signs AppClaim messages
BACKEND_PRIVATE_KEY=0x...
VALOR_APP_ADDRESS=0x...
ENGAGEMENT_REWARDS_CONTRACT=                # optional override

# ── Decay Cron ────────────────────────────────────────────────
DECAY_CRON_SECRET=                          # openssl rand -hex 32


# ╔══════════════════════════════════════════════════════════════╗
# ║  contracts/  (.env)                                          ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Foundry deployment ────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...
CELO_RPC_URL=https://forno.celo.org
CELOSCAN_API_KEY=                           # for contract verification
